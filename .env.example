# Copy to .env.local and fill in. NEVER commit real values.
# On Vercel, set these in Project Settings → Environment Variables.

# --- Auth.js / NextAuth v5 (admin login) ---
# Generate a secret with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=
# Google OAuth client (console.cloud.google.com → APIs & Services → Credentials).
# Authorized redirect URI: https://surreal4you.com/api/auth/callback/google
# and http://localhost:3000/api/auth/callback/google for local dev.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Comma-separated list of emails allowed into /admin.
ADMIN_EMAILS=

# --- Vercel Blob (admin content store + image uploads) ---
# On Vercel this is injected automatically once a Blob store is connected.
# Locally: `vercel env pull .env.local` or copy from the Vercel dashboard.
# If unset locally, the admin falls back to a .data/content.json file (dev only).
BLOB_READ_WRITE_TOKEN=
